---
interface Props {
  href: string;
  eyebrow?: string;
  title: string;
  summary: string;
  role?: string;
  tags?: string[];
  featured?: boolean;
  confidential?: boolean;
  status?: string;
  category?: "qms" | "tasis" | "personal";
}

const {
  href,
  eyebrow,
  title,
  summary,
  role,
  tags = [],
  featured = false,
  confidential = false,
  status,
  category,
} = Astro.props;

const s = (status ?? "").toLowerCase();
const isProgress =
  s.includes("progress") ||
  s.includes("coming") ||
  s.includes("ongoing") ||
  s.includes("planned");
const isComingSoon = s.includes("coming");
---

<a
  href={href}
  class:list={[
    "project-card",
    category && `cat-${category}`,
    { featured, "coming-soon": isComingSoon },
  ]}
>
  <span class="card-stripe" aria-hidden="true"></span>

  <div class="card-top">
    {eyebrow && (
      <span class="card-eyebrow eyebrow">
        {category && <span class="cat-dot" aria-hidden="true"></span>}
        {eyebrow}
      </span>
    )}
    <div class="card-status">
      {confidential && (
        <span class="tag tag-confidential" title="Redacted for confidentiality">
          Redacted
        </span>
      )}
      {status && (
        <span class:list={["tag", isProgress && "tag-accent", "tag-dot"]}>
          {status}
        </span>
      )}
    </div>
  </div>

  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-summary">{summary}</p>
  </div>

  <div class="card-foot">
    {role && <span class="card-meta muted">{role}</span>}
    {tags.length > 0 && (
      <ul class="card-tags" aria-label="Tools and skills">
        {tags.slice(0, 3).map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}
    <span class="card-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-7);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      background var(--dur-base) var(--ease-out);
    overflow: hidden;
    height: 100%;
    color: var(--color-ink);
  }

  .project-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
    background: var(--color-bg-muted);
  }

  .project-card.coming-soon {
    background: transparent;
    border-style: dashed;
  }

  .project-card.coming-soon:hover {
    background: var(--color-bg-elevated);
  }

  /* Category gradient stripe — sits at the very top, 2px,
     scales to 3px on hover. Subtle identity, never decoration. */
  .card-stripe {
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out),
      height var(--dur-base) var(--ease-out);
  }

  .project-card.cat-qms .card-stripe {
    background: var(--grad-qms);
    opacity: 1;
  }

  .project-card.cat-tasis .card-stripe {
    background: var(--grad-tasis);
    opacity: 1;
  }

  .project-card.cat-personal .card-stripe {
    background: var(--grad-personal);
    opacity: 1;
  }

  .project-card:hover .card-stripe {
    height: 3px;
  }

  /* Soft category glow on hover — sits behind content. Apple-style depth. */
  .project-card::after {
    content: "";
    position: absolute;
    pointer-events: none;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 60%;
    border-radius: 50%;
    opacity: 0;
    filter: blur(48px);
    transition: opacity var(--dur-slow) var(--ease-out);
    z-index: 0;
  }

  .project-card.cat-qms::after { background: var(--cat-qms-ink); }
  .project-card.cat-tasis::after { background: var(--cat-tasis-ink); }
  .project-card.cat-personal::after { background: var(--cat-personal-ink); }

  .project-card:hover::after {
    opacity: 0.18;
  }

  /* Layer content above the glow */
  .card-top,
  .card-body,
  .card-foot {
    position: relative;
    z-index: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .card-eyebrow {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* Small category dot beside the eyebrow text */
  .cat-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .cat-qms .cat-dot { background: var(--grad-qms); }
  .cat-tasis .cat-dot { background: var(--grad-tasis); }
  .cat-personal .cat-dot { background: var(--grad-personal); }

  .card-status {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-title {
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
    color: var(--color-ink);
  }

  .card-summary {
    color: var(--color-ink-secondary);
    font-size: var(--fs-base);
    line-height: var(--lh-base);
  }

  .card-foot {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--fs-sm);
  }

  .card-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    list-style: none;
  }

  .card-arrow {
    margin-left: auto;
    color: var(--color-ink-muted);
    transition: transform var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .project-card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--color-ink);
  }
</style>
