---
import "~/styles/global.css";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { site } from "~/data/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  ogImage,
  ogType = "website",
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : site.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin)
  .toString();

// Default OG image lives at /og-image.png in public/. Per-page override via prop.
const ogImageUrl = new URL(
  ogImage ?? "/og-image.png",
  Astro.site ?? Astro.url.origin,
).toString();
const ogImageAlt = `${site.fullName}. UX/UI designer and digital marketing specialist.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/space-grotesk-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {!noindex && <link rel="canonical" href={canonical} />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="theme-color" content="#0a0d12" />

    <slot name="head" />

    <script is:inline>document.documentElement.classList.add('js');try{var t=localStorage.getItem('theme');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Ambient atmosphere, scroll reveals, and pinned horizontal-scroll
      // sections. Content never depends on this file: the hidden pre-reveal
      // state is gated on the `js` class set by the inline bootstrap in
      // <head>, so everything stays visible if this module never runs.
      const doc = document.documentElement;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function revealAll() {
        document
          .querySelectorAll("[data-reveal]")
          .forEach((el) => el.classList.add("is-revealed"));
      }

      if (reduceMotion) {
        doc.style.setProperty("--mx", "50vw");
        doc.style.setProperty("--my", "35vh");
        revealAll();
      } else {
        // ---- Pointer-driven ambient (smoothed via requestAnimationFrame) ----
        // The loop runs only while the smoothed position is still converging
        // toward the pointer; once it settles, no frames are burned until
        // the pointer moves again.
        let tx = 50;
        let ty = 35;
        let cx = tx;
        let cy = ty;
        let ambientRunning = false;

        function ambientTick() {
          // simple lerp; feels alive without being twitchy
          cx += (tx - cx) * 0.045;
          cy += (ty - cy) * 0.045;
          if (Math.abs(tx - cx) < 0.01 && Math.abs(ty - cy) < 0.01) {
            cx = tx;
            cy = ty;
            ambientRunning = false;
          }
          doc.style.setProperty("--mx", cx.toFixed(2) + "vw");
          doc.style.setProperty("--my", cy.toFixed(2) + "vh");
          if (ambientRunning) requestAnimationFrame(ambientTick);
        }

        function startAmbient() {
          if (ambientRunning) return;
          ambientRunning = true;
          requestAnimationFrame(ambientTick);
        }

        window.addEventListener(
          "pointermove",
          (e) => {
            tx = (e.clientX / window.innerWidth) * 100;
            ty = (e.clientY / window.innerHeight) * 100;
            startAmbient();
          },
          { passive: true },
        );

        // ---- Scroll progress (0..1) ----
        function onScroll() {
          const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const sp = Math.min(1, Math.max(0, window.scrollY / max));
          doc.style.setProperty("--sp", sp.toFixed(3));
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();

        // ---- Scroll reveals ----
        if ("IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-revealed");
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
          );
          document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
        } else {
          revealAll();
        }

        // ---- Horizontal-scroll-on-vertical sections ----
        // Each section keeps a target (scroll-derived) and a smoothed value
        // that lerps toward the target every frame. This makes trackpad,
        // mouse-wheel, and touch all feel uniformly smooth without changing
        // how fast the user can move through the section.
        const hScrollSections = document.querySelectorAll(".h-scroll");
        if (hScrollSections.length) {
          const hReduce = window.matchMedia("(prefers-reduced-motion: reduce)");
          const hMobile = window.matchMedia("(max-width: 720px)");
          const hFallback = () => hReduce.matches || hMobile.matches;

          type HController = {
            measure: () => void;
            readTarget: () => void;
            /** Advances one frame; returns true while still converging. */
            tick: () => boolean;
          };
          const hControllers: HController[] = [];

          hScrollSections.forEach((el) => {
            if (!(el instanceof HTMLElement)) return;
            // Fresh const so the narrowed type survives into the closures.
            const section = el;
            const viewport = section.querySelector(".h-scroll__viewport");
            const track = section.querySelector(".h-scroll__track");
            if (!viewport || !track) return;

            const state = { target: 0, current: 0 };

            function measure() {
              if (hFallback()) {
                section.style.setProperty("--h-scroll-distance", "0px");
                section.style.setProperty("--hx", "0");
                return;
              }
              const distance = Math.max(0, track!.scrollWidth - viewport!.clientWidth);
              section.style.setProperty("--h-scroll-distance", distance + "px");
            }

            function readTarget() {
              if (hFallback()) return;
              const rect = section.getBoundingClientRect();
              const totalScroll = section.offsetHeight - window.innerHeight;
              if (totalScroll <= 0) return;
              const raw = -rect.top / totalScroll;
              state.target = Math.min(1, Math.max(0, raw));
            }

            function tick() {
              if (hFallback()) return false;
              // Lerp with factor 0.18; converges in ~4–5 frames without
              // feeling laggy on fast scroll input.
              state.current += (state.target - state.current) * 0.18;
              // Snap when within a tiny epsilon to stop the GPU from doing
              // sub-pixel work forever.
              if (Math.abs(state.target - state.current) < 0.0005) {
                state.current = state.target;
              }
              section.style.setProperty("--hx", state.current.toFixed(4));
              return state.current !== state.target;
            }

            hControllers.push({ measure, readTarget, tick });
            measure();
            readTarget();
            state.current = state.target;
            section.style.setProperty("--hx", state.current.toFixed(4));

            // Keyboard and find-in-page support. The track moves via
            // transform, which browser scroll logic knows nothing about, so
            // two corrections keep focused content actually visible:
            // 1) focusin (keyboard only) centers the focused card by jumping
            //    the page to the equivalent runway position;
            // 2) any native scroll of the hidden-overflow viewport (focus or
            //    find-in-page reveals) is absorbed into the runway instead.
            // Both jump instantly: these are corrections, and the page
            // position must match the track before the next key press.
            // Geometry comes from measure()'s cached values, not fresh reads:
            // event-time layout flushes can transiently report zero widths.
            function railDistance() {
              const cached = parseFloat(section.style.getPropertyValue("--h-scroll-distance"));
              return cached > 0 ? cached : Math.max(1, track!.scrollWidth - viewport!.clientWidth);
            }

            function jumpTo(hx: number) {
              const totalScroll = section.offsetHeight - window.innerHeight;
              if (totalScroll <= 0) return;
              const sectionTop = section.getBoundingClientRect().top + window.scrollY;
              state.target = hx;
              state.current = hx;
              section.style.setProperty("--hx", hx.toFixed(4));
              window.scrollTo({ top: sectionTop + hx * totalScroll, behavior: "instant" });
            }

            viewport.addEventListener("focusin", (e) => {
              if (hFallback()) return;
              // :focus-visible keeps mouse clicks from jumping the page.
              if (!(e.target instanceof Element) || !e.target.matches(":focus-visible")) return;
              const item = e.target.closest(".h-scroll__item");
              if (!(item instanceof HTMLElement)) return;
              const distance = railDistance();
              const vw = viewport.clientWidth || window.innerWidth;
              const centered = item.offsetLeft + item.offsetWidth / 2 - vw / 2;
              jumpTo(Math.min(1, Math.max(0, centered / distance)));
            });

            viewport.addEventListener(
              "scroll",
              () => {
                if (hFallback()) return;
                const nativeScroll = viewport.scrollLeft;
                if (nativeScroll === 0) return;
                viewport.scrollLeft = 0;
                jumpTo(Math.min(1, Math.max(0, nativeScroll / railDistance())));
              },
              { passive: true },
            );
          });

          // One shared RAF loop for all h-scroll sections. It parks itself
          // once every section has converged and is restarted by scroll,
          // resize, or breakpoint changes — which also revives the effect
          // after crossing the mobile breakpoint without a reload.
          let hRunning = false;

          function hLoop() {
            let converging = false;
            for (const c of hControllers) {
              if (c.tick()) converging = true;
            }
            if (converging) {
              requestAnimationFrame(hLoop);
            } else {
              hRunning = false;
            }
          }

          function startHLoop() {
            if (hRunning || hFallback()) return;
            hRunning = true;
            requestAnimationFrame(hLoop);
          }

          function hOnScroll() {
            for (const c of hControllers) c.readTarget();
            startHLoop();
          }
          function hOnResize() {
            for (const c of hControllers) {
              c.measure();
              c.readTarget();
            }
            startHLoop();
          }

          window.addEventListener("scroll", hOnScroll, { passive: true });
          window.addEventListener("resize", hOnResize, { passive: true });
          hReduce.addEventListener("change", hOnResize);
          hMobile.addEventListener("change", hOnResize);
          startHLoop();
        }
      }
    </script>
  </body>
</html>
