---
import "~/styles/global.css";
import Nav from "~/components/Nav.astro";
import Footer from "~/components/Footer.astro";
import { site } from "~/data/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  ogImage,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : site.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin)
  .toString();

// Default OG image lives at /og-image.png in public/. Per-page override via prop.
const ogImageUrl = new URL(
  ogImage ?? "/og-image.png",
  Astro.site ?? Astro.url.origin,
).toString();
const ogImageAlt = `${site.fullName}. UX/UI designer and digital marketing specialist.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="theme-color" content="#0a0d12" />

    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Ambient atmosphere, scroll reveals, and pinned horizontal-scroll
      // sections. Content never depends on this file: the hidden pre-reveal
      // state is gated on the `js` class set by the inline bootstrap in
      // <head>, so everything stays visible if this module never runs.
      const doc = document.documentElement;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function revealAll() {
        document
          .querySelectorAll("[data-reveal]")
          .forEach((el) => el.classList.add("is-revealed"));
      }

      if (reduceMotion) {
        doc.style.setProperty("--mx", "50%");
        doc.style.setProperty("--my", "35%");
        revealAll();
      } else {
        // ---- Pointer-driven ambient (smoothed via requestAnimationFrame) ----
        let tx = 50;
        let ty = 35;
        let cx = tx;
        let cy = ty;
        window.addEventListener(
          "pointermove",
          (e) => {
            tx = (e.clientX / window.innerWidth) * 100;
            ty = (e.clientY / window.innerHeight) * 100;
          },
          { passive: true },
        );

        function tick() {
          // simple lerp; feels alive without being twitchy
          cx += (tx - cx) * 0.045;
          cy += (ty - cy) * 0.045;
          doc.style.setProperty("--mx", cx.toFixed(2) + "%");
          doc.style.setProperty("--my", cy.toFixed(2) + "%");
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);

        // ---- Scroll progress (0..1) ----
        function onScroll() {
          const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const sp = Math.min(1, Math.max(0, window.scrollY / max));
          doc.style.setProperty("--sp", sp.toFixed(3));
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();

        // ---- Scroll reveals ----
        if ("IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-revealed");
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
          );
          document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
        } else {
          revealAll();
        }

        // ---- Horizontal-scroll-on-vertical sections ----
        // Each section keeps a target (scroll-derived) and a smoothed value
        // that lerps toward the target every frame. This makes trackpad,
        // mouse-wheel, and touch all feel uniformly smooth without changing
        // how fast the user can move through the section.
        const hScrollSections = document.querySelectorAll(".h-scroll");
        if (hScrollSections.length) {
          const hReduce = window.matchMedia("(prefers-reduced-motion: reduce)");
          const hMobile = window.matchMedia("(max-width: 720px)");
          const hFallback = () => hReduce.matches || hMobile.matches;

          type HController = {
            measure: () => void;
            readTarget: () => void;
            tick: () => void;
          };
          const hControllers: HController[] = [];

          hScrollSections.forEach((section) => {
            if (!(section instanceof HTMLElement)) return;
            const viewport = section.querySelector(".h-scroll__viewport");
            const track = section.querySelector(".h-scroll__track");
            if (!viewport || !track) return;

            const state = { target: 0, current: 0 };

            function measure() {
              if (hFallback()) {
                section.style.setProperty("--h-scroll-distance", "0px");
                section.style.setProperty("--hx", "0");
                return;
              }
              const distance = Math.max(0, track!.scrollWidth - viewport!.clientWidth);
              section.style.setProperty("--h-scroll-distance", distance + "px");
            }

            function readTarget() {
              if (hFallback()) return;
              const rect = section.getBoundingClientRect();
              const totalScroll = section.offsetHeight - window.innerHeight;
              if (totalScroll <= 0) return;
              const raw = -rect.top / totalScroll;
              state.target = Math.min(1, Math.max(0, raw));
            }

            function tick() {
              if (hFallback()) return;
              // Lerp with factor 0.18; converges in ~4–5 frames without
              // feeling laggy on fast scroll input.
              state.current += (state.target - state.current) * 0.18;
              // Snap when within a tiny epsilon to stop the GPU from doing
              // sub-pixel work forever.
              if (Math.abs(state.target - state.current) < 0.0005) {
                state.current = state.target;
              }
              section.style.setProperty("--hx", state.current.toFixed(4));
            }

            hControllers.push({ measure, readTarget, tick });
            measure();
            readTarget();
            state.current = state.target;
            section.style.setProperty("--hx", state.current.toFixed(4));
          });

          function hLoop() {
            for (const c of hControllers) c.tick();
            requestAnimationFrame(hLoop);
          }
          // Run a single shared RAF loop for all h-scroll sections.
          if (!hReduce.matches && !hMobile.matches) {
            requestAnimationFrame(hLoop);
          }

          function hOnScroll() {
            for (const c of hControllers) c.readTarget();
          }
          function hOnResize() {
            for (const c of hControllers) {
              c.measure();
              c.readTarget();
            }
          }

          window.addEventListener("scroll", hOnScroll, { passive: true });
          window.addEventListener("resize", hOnResize, { passive: true });
          hReduce.addEventListener("change", hOnResize);
          hMobile.addEventListener("change", hOnResize);
        }
      }
    </script>
  </body>
</html>
